{
  "app-id": "io.github.mentaldefeur.AutoUnlockCryptnux",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "auto-unlock-cryptnux-gui",
  "finish-args": [
    "--share=ipc",
    "--socket=x11",
    "--socket=wayland",
    "--device=all",
    "--filesystem=host",
    "--system-talk-name=org.freedesktop.DBus.System",
    "--talk-name=org.freedesktop.Notifications"
  ],
  "modules": [
    {
      "name": "python3-pyqt5",
      "buildsystem": "simple",
      "build-options": {
        "build-args": [
          "--share=network"
        ]
      },
      "build-commands": [
        "pip3 install --no-build-isolation --prefix=/app PyQt5"
      ]
    },
    {
      "name": "auto-unlock-cryptnux",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm644 auto_unlock_cryptnux.py /app/lib/auto-unlock-cryptnux/auto_unlock_cryptnux.py",
        "install -Dm644 auto_unlock_cryptnux_gui.py /app/lib/auto-unlock-cryptnux/auto_unlock_cryptnux_gui.py",
        "install -Dm755 flatpak/wrapper-cli.sh /app/bin/auto-unlock-cryptnux",
        "install -Dm755 flatpak/wrapper-gui.sh /app/bin/auto-unlock-cryptnux-gui",
        "install -Dm644 flatpak/io.github.mentaldefeur.AutoUnlockCryptnux.desktop /app/share/applications/io.github.mentaldefeur.AutoUnlockCryptnux.desktop",
        "install -Dm644 flatpak/io.github.mentaldefeur.AutoUnlockCryptnux.metainfo.xml /app/share/metainfo/io.github.mentaldefeur.AutoUnlockCryptnux.metainfo.xml",
        "install -Dm644 flatpak/io.github.mentaldefeur.AutoUnlockCryptnux.svg /app/share/icons/hicolor/scalable/apps/io.github.mentaldefeur.AutoUnlockCryptnux.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": ".."
        }
      ]
    }
  ]
}
