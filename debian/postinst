#!/bin/bash
set -e

case "$1" in
    configure)
        # Rendre les scripts exécutables
        chmod +x /usr/bin/auto-unlock-cryptnux
        chmod +x /usr/bin/auto-unlock-cryptnux-gui

        echo ""
        echo "=== AutoUnlockCryptnux installé ==="
        echo ""
        echo "Vérifiez les dépendances :"
        echo "  sudo auto-unlock-cryptnux check"
        echo ""
        echo "Lier une partition LUKS au TPM2 :"
        echo "  sudo auto-unlock-cryptnux bind /dev/sdXY"
        echo ""
        echo "Interface graphique :"
        echo "  sudo auto-unlock-cryptnux-gui"
        echo ""
        ;;
esac

exit 0
