#!/bin/bash
set -e

case "$1" in
    remove|purge)
        echo "Suppression d'AutoUnlockCryptnux..."
        echo "Note : les liaisons TPM2 existantes ne sont PAS supprimées automatiquement."
        echo "Pour supprimer une liaison : sudo auto-unlock-cryptnux unbind /dev/sdXY"
        ;;
esac

exit 0
